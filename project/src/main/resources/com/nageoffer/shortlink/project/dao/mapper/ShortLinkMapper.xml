<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd" >
<mapper namespace="com.nageoffer.shortlink.project.dao.mapper.ShortLinkMapper">

    <update id="updateShortLink">
        update t_link
        <trim prefix="set" suffixOverrides=",">
            <if test="originUrl != null and originUrl != ''">
                origin_url = #{originUrl},
            </if>
            <if test="description != null">
                description = #{description},
            </if>
            <if test="validDataType != null">
                valid_data_type = #{validDataType},
                <choose>
                    <when test="validDataType == 0">
                        valid_data = null,
                    </when>
                    <otherwise>
                        valid_data = #{validData},
                    </otherwise>
                </choose>
            </if>
        </trim>
        where full_short_url = #{fullShortUrl}
          and gid = #{originGid}
          and enable_status = 0
          and del_flag = 0
    </update>

    <select id="listGroupShortLinkCount" resultType="com.nageoffer.shortlink.project.dto.Resp.ShortLinkGroupCountQueryRespDTO">
        select gid,count(*) as shortLinkCount from t_link where gid in
        <foreach collection="gids" item="gid" open="(" close=")" separator=",">
                #{gid}
        </foreach>
        and enable_status=0
        group by gid
    </select>
    <select id="recycleBinPageReqDTO" resultType="com.nageoffer.shortlink.project.dto.Resp.RecycleBinPageRespDTO">
        select from t_link where gid in
        <foreach collection="list" item="gid" open="(" close=")" separator=",">
              #{gid}
        </foreach>
        and enable_status=0
        group
    </select>

</mapper>