<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd" >
<mapper namespace="com.nageoffer.shortlink.project.dao.mapper.LinkNetworkStatsMapper">


    <insert id="shortLinkNetworkStats">
        INSERT INTO t_link_network_stats
        (id,
         full_short_url,
         gid,
         `date`,
         cnt,
         create_time,
         update_time,
         del_flag,
         network
        ) VALUES (
                     #{id},
                     #{fullShortUrl},
                     #{gid},
                     #{date},
                     #{cnt},
                     NOW(),
                     NOW(),
                     0,
                     #{network}
                 )
            ON DUPLICATE KEY UPDATE
                                 cnt = cnt + #{cnt},
                                 update_time = NOW()
    </insert>
</mapper>